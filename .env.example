# Copy to .env and fill in. Generate a secret key with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
DILBYRT_SECRET_KEY=change-me-to-a-long-random-string

# First-boot admin account (only used when the user table is empty).
DILBYRT_ADMIN_USERNAME=admin
DILBYRT_ADMIN_PASSWORD=change-me
DILBYRT_ADMIN_EMAIL=you@example.com
